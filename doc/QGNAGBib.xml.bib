  url =              {https://www.sciencedirect.com/science/article/pii/S0021869313004985},
  keywords =         {Pointed Hopf algebras, Copointed Hopf algebras, Affine racks, Nichols algebras},
  abstract =         {We  study  the  pointed  or copointed liftings of Nichols algebras associated to affine
                      racks   and   constant   cocycles   for   any   finite   group  admitting  a  principal
